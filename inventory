#!/bin/bash

filename="$HOME/.inventory"
checkout_file="$HOME/.inventory_checkout"

if [ ! -f "$filename" ]; then
  touch "$filename"
fi

case "$1" in
  checkout|search|remove|update|move|rename)
    if ! command -v fzf &>/dev/null; then
      echo "Error: fzf is not installed. Install it with your package manager."
      exit 1
    fi
    ;;&
  add)
    read -r -p "Container: " container
    container="${container//$'\t'/ }"
    if [ -z "$container" ]; then
      echo "Container cannot be empty"
      exit 1
    fi

    while true; do
      read -r -p "Item: " item
      item="${item//$'\t'/ }"
      if [ -z "$item" ]; then
        break
      fi

      existing=$(awk -F'\t' -v c="$container" -v i="$item" '$1==c && $3==i {print $2; exit}' "$filename")
      if [ -n "$existing" ]; then
        echo "\"$item\" already exists in \"$container\" (quantity: $existing)."
        read -r -p "Update quantity instead? [y/N] " confirm
        if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
          while true; do
            read -r -p "New quantity: " quantity
            if [ -z "$quantity" ]; then quantity=1; fi
            if [ "$quantity" -eq "$quantity" ] 2>/dev/null; then break; fi
            echo "Quantity must be a number"
          done
          old_line="$container	$existing	$item"
          new_line="$container	$quantity	$item"
          awk -v l="$old_line" 'BEGIN{done=0} !done && $0==l {done=1; next} {print}' "$filename" > "$filename.tmp" && echo "$new_line" >> "$filename.tmp" && mv "$filename.tmp" "$filename"
        fi
        continue
      fi

      while true; do
        read -r -p "Quantity: " quantity
        if [ -z "$quantity" ]; then
          quantity=1
        fi
        if [ "$quantity" -eq "$quantity" ] 2>/dev/null; then
          break
        fi
        echo "Quantity must be a number"
      done

      echo "$container	$quantity	$item" >> "$filename"
    done
    ;;
  checkout)
    if [ ! -f "$checkout_file" ]; then
      touch "$checkout_file"
    fi

    item=$(fzf < "$filename")
    if [ -z "$item" ]; then
      exit 1
    fi

    in_or_out=$(printf "in\nout" | fzf)
    if [ -z "$in_or_out" ]; then
      exit 1
    fi

    echo "$item	$in_or_out	$(date)" >> "$checkout_file"
    tail -1 "$checkout_file"
    ;;
  containers)
    cut -f1 "$filename" | sort | uniq -c
    ;;
  search)
    if [ -n "$2" ]; then
      grep -Fi "$2" "$filename"
    else
      fzf < "$filename"
    fi
    ;;
  count)
    echo "Entries: $(wc -l < "$filename")"
    echo "Total quantity: $(awk -F'\t' '{sum += $2} END {print sum+0}' "$filename")"
    ;;
  show)
    if [ -n "$2" ]; then
      containers="$2"
    else
      containers=$(cut -f1 "$filename" | sort | uniq)
    fi
    echo "$containers" | while read -r container; do
      echo "$container"
      awk -F'\t' -v c="$container" '$1 == c {qty[$3] += $2} END {for (item in qty) print qty[item], item}' "$filename" | sort -k1,1n -k2 | while read -r line; do
        echo "  $line"
      done
    done
    ;;
  update)
    line=$(fzf < "$filename")
    if [ -z "$line" ]; then
      exit 1
    fi

    while true; do
      read -r -p "New quantity: " quantity
      if [ -z "$quantity" ]; then
        quantity=1
      fi
      if [ "$quantity" -eq "$quantity" ] 2>/dev/null; then
        break
      fi
      echo "Quantity must be a number"
    done

    container=$(echo "$line" | cut -f1)
    item=$(echo "$line" | cut -f3)
    new_line="$container	$quantity	$item"
    awk -v l="$line" 'BEGIN{done=0} !done && $0==l {done=1; next} {print}' "$filename" > "$filename.tmp" && echo "$new_line" >> "$filename.tmp" && mv "$filename.tmp" "$filename"
    ;;
  move)
    line=$(fzf < "$filename")
    if [ -z "$line" ]; then
      exit 1
    fi

    read -r -p "New container: " new_container
    if [ -z "$new_container" ]; then
      echo "Container cannot be empty"
      exit 1
    fi

    quantity=$(echo "$line" | cut -f2)
    item=$(echo "$line" | cut -f3)
    new_line="$new_container	$quantity	$item"
    awk -v l="$line" 'BEGIN{done=0} !done && $0==l {done=1; next} {print}' "$filename" > "$filename.tmp" && echo "$new_line" >> "$filename.tmp" && mv "$filename.tmp" "$filename"
    ;;
  remove)
    line=$(fzf < "$filename")
    if [ -z "$line" ]; then
      exit 1
    fi
    read -r -p "Remove \"$line\"? [y/N] " confirm
    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
      echo "Aborted."
      exit 0
    fi
    awk -v l="$line" 'BEGIN{done=0} !done && $0==l {done=1; next} {print}' "$filename" > "$filename.tmp" && mv "$filename.tmp" "$filename"
    ;;
  rename)
    old_container=$(cut -f1 "$filename" | sort | uniq | fzf)
    if [ -z "$old_container" ]; then
      exit 1
    fi

    read -r -p "New container name: " new_container
    if [ -z "$new_container" ]; then
      echo "Container name cannot be empty"
      exit 1
    fi

    awk -F'\t' -v old="$old_container" -v new="$new_container" 'BEGIN{OFS="\t"} $1 == old {$1 = new} {print}' "$filename" > "$filename.tmp"
    mv "$filename.tmp" "$filename"
    ;;
  status)
    if [ ! -f "$checkout_file" ]; then
      echo "No checkout history."
      exit 0
    fi
    awk -F'\t' '{key=$1 FS $2 FS $3; state[key]=$4} END {for (k in state) if (state[k]=="out") print k}' "$checkout_file" | sort | column -t -s $'\t'
    ;;
  history)
    if [ ! -f "$checkout_file" ]; then
      echo "No checkout history."
      exit 0
    fi
    if [ -n "$2" ]; then
      grep -Fi "$2" "$checkout_file" | column -t -s $'\t'
    else
      column -t -s $'\t' < "$checkout_file"
    fi
    ;;
  export)
    json_escape() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\r/\\r/g'; }
    case "$2" in
      json)
        echo "["
        first=1
        while IFS=$'\t' read -r container quantity item; do
          [ "$first" -eq 1 ] && first=0 || echo ","
          printf '  {"container":"%s","quantity":%s,"item":"%s"}' "$(json_escape "$container")" "$quantity" "$(json_escape "$item")"
        done < "$filename"
        echo ""
        echo "]"
        ;;
      csv|"")
        echo "container,quantity,item"
        while IFS=$'\t' read -r container quantity item; do
          printf '"%s",%s,"%s"\n' "${container//\"/\"\"}" "$quantity" "${item//\"/\"\"}"
        done < "$filename"
        ;;
      *)
        echo "Usage: inventory export [csv|json]"
        exit 1
        ;;
    esac
    ;;
  import)
    if [ -z "$2" ]; then
      echo "Usage: inventory import <file>"
      exit 1
    fi
    if [ ! -f "$2" ]; then
      echo "File not found: $2"
      exit 1
    fi
    python3 - "$2" "$filename" <<'PYEOF'
import csv, sys
with open(sys.argv[1], newline='') as f:
    reader = csv.reader(f)
    next(reader, None)
    with open(sys.argv[2], 'a') as out:
        for row in reader:
            if len(row) < 3:
                print(f"Skipping short line: {row}")
                continue
            container, quantity, item = row[0], row[1].strip(), row[2]
            try:
                int(quantity)
                out.write(f"{container}\t{quantity}\t{item}\n")
            except ValueError:
                print(f"Skipping invalid quantity: {row}")
PYEOF
    ;;
  edit)
    ${EDITOR:-vi} "$filename"
    ;;
  help|--help|-h|"")
    echo "Usage: inventory <command>"
    echo "Commands:"
    echo "  add - Add an item to the inventory"
    echo "  checkout - Checkout an item from the inventory"
    echo "  containers - List all containers"
    echo "  search - Search the inventory"
    echo "  count - Count the number of items in the inventory"
    echo "  show - Show the inventory"
    echo "  update - Update the quantity of an item"
    echo "  move - Move an item to a different container"
    echo "  remove - Remove an item from the inventory"
    echo "  rename - Rename a container"
    echo "  history - Show checkout history"
    echo "  status - Show currently checked out items"
    echo "  export - Export inventory as CSV or JSON"
    echo "  import - Import inventory from a CSV file"
    echo "  edit - Edit the inventory"
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'inventory help' for usage."
    exit 1
    ;;
esac
